#Q10) Count letters, digits, and special symbols in a string.
Input: "P@#yn26at^&i5ve"
Chars=8, Digits=3, Symbols=4

code:)
text = input("Enter a string: ")

chars = 0
digits = 0
symbols = 0

for i in text:
    if i.isalpha():
        chars += 1
    elif i.isdigit():
        digits += 1
    else:
        symbols += 1

print("Chars =", chars)
print("Digits =", digits)
print("Symbols =", symbols)

